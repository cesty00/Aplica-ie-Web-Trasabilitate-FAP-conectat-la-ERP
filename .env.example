# App
NODE_ENV=development
APP_NAME=FAP Traceability
APP_PORT=3001
WEB_PORT=3000

# Database
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/fap_traceability

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_ACCESS_SECRET=<set_locally>
JWT_REFRESH_SECRET=<set_locally>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=<set_locally>
S3_SECRET_KEY=<set_locally>
S3_BUCKET=fap-documents
S3_REGION=eu-central-1

# OpenAI - reserved for later sprint, not used in Sprint 0 or Sprint 1 validation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-thinking

# Import limits - reserved for Import Engine in later sprint
MAX_IMPORT_FILE_SIZE_MB=50
IMPORT_BATCH_SIZE=1000
